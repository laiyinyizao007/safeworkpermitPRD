{
  "version": "1.0.0",
  "nodeLibrary": {
    "layer1_universal": {
      "description": "通用底座节点（跨行业复用）",
      "nodes": [
        {
          "id": "填写-表单",
          "type": "FormFieldNode",
          "layer": 1,
          "reusability": "universal",
          "config": {
            "formSchemaRef": "hot_work_metadata.json#formSchema"
          }
        },
        {
          "id": "审批-通用",
          "type": "ApprovalNode",
          "layer": 1,
          "reusability": "universal",
          "config": {
            "approvalLevels": ["一级审批", "二级审批", "三级审批"],
            "autoEscalation": true
          }
        },
        {
          "id": "签名-电子",
          "type": "SignatureNode",
          "layer": 1,
          "reusability": "universal",
          "config": {
            "signatureType": "electronic",
            "biometricSupport": false
          }
        },
        {
          "id": "上传-附件",
          "type": "AttachmentNode",
          "layer": 1,
          "reusability": "universal",
          "config": {
            "allowedTypes": ["image", "video", "document"],
            "maxSize": "50MB"
          }
        }
      ]
    },
    "layer2_business": {
      "description": "行业无关业务节点",
      "nodes": [
        {
          "id": "匹配-审批级别",
          "type": "RuleNode",
          "layer": 2,
          "reusability": "business",
          "config": {
            "ruleEngine": "jexl",
            "rules": [
              {
                "condition": "data.work_level == 'special'",
                "action": "setApprovalLevel",
                "params": { "level": 3 }
              },
              {
                "condition": "data.work_level == 'level1'",
                "action": "setApprovalLevel",
                "params": { "level": 2 }
              },
              {
                "condition": "data.work_level == 'level2'",
                "action": "setApprovalLevel",
                "params": { "level": 1 }
              }
            ]
          }
        },
        {
          "id": "检测-冲突",
          "type": "ConflictDetectionNode",
          "layer": 2,
          "reusability": "business",
          "config": {
            "conflictTypes": ["time_overlap", "location_overlap", "resource_conflict"],
            "autoResolve": false
          }
        },
        {
          "id": "通知-相关方",
          "type": "NotificationNode",
          "layer": 2,
          "reusability": "business",
          "config": {
            "channels": ["email", "sms", "app_push"],
            "templates": {}
          }
        }
      ]
    },
    "layer3_industry": {
      "description": "EHS 行业特定节点",
      "nodes": [
        {
          "id": "检测-气体浓度",
          "type": "IoTNode",
          "layer": 3,
          "reusability": "industry_specific",
          "config": {
            "deviceType": "gas_detector",
            "parameters": ["combustible_gas", "oxygen", "toxic_gas"],
            "thresholds": {
              "combustible_gas": { "max": 0.5, "unit": "%LEL" },
              "oxygen": { "min": 19.5, "max": 23.5, "unit": "%" }
            },
            "autoRecord": true
          }
        },
        {
          "id": "验证-资质证书",
          "type": "CertificationNode",
          "layer": 3,
          "reusability": "industry_specific",
          "config": {
            "certificateTypes": ["gas_detection", "hot_work", "confined_space"],
            "validityCheck": true,
            "expiryWarning": 30
          }
        },
        {
          "id": "执行-动火作业",
          "type": "WorkExecutionNode",
          "layer": 3,
          "reusability": "industry_specific",
          "config": {
            "workType": "hot_work",
            "safetyChecklist": [
              "fire_extinguishers",
              "blind_plate_isolation",
              "gas_detection",
              "warning_area",
              "combustible_cleared"
            ],
            "realTimeMonitoring": true
          }
        },
        {
          "id": "检查-安全措施",
          "type": "SafetyCheckNode",
          "layer": 3,
          "reusability": "industry_specific",
          "config": {
            "checklistRef": "constraintRules.json#hardConstraints",
            "photoRequired": true,
            "minPhotos": 3
          }
        },
        {
          "id": "环境准入-闸门",
          "type": "EnvironmentGateNode",
          "layer": 3,
          "reusability": "industry_specific",
          "config": {
            "steps": ["gas_detection", "personnel_verification", "safety_checklist", "admission_control"],
            "sequential": true,
            "gasValidityMinutes": 30,
            "geoFenceRequired": true,
            "geoFenceRadius": 100,
            "autoBlockConditions": [
              { "field": "gas_oxygen", "condition": "< 19.5 || > 23.5" },
              { "field": "gas_combustible", "condition": "> 0.5" }
            ]
          }
        }
      ]
    },
    "layer4_plugins": {
      "description": "微场景插件节点（可插拔部署）",
      "nodes": [
        {
          "id": "plugin-罐区动火",
          "type": "PluginNode",
          "layer": 4,
          "reusability": "micro_scenario",
          "pluginPackage": "@ehs/tank-area-hotwork",
          "config": {
            "additionalChecks": ["tank_pressure", "wind_direction", "temperature"],
            "exclusionZone": "30m",
            "videoRequired": true
          }
        },
        {
          "id": "plugin-装置区动火",
          "type": "PluginNode",
          "layer": 4,
          "reusability": "micro_scenario",
          "pluginPackage": "@ehs/facility-hotwork",
          "config": {
            "shutdownRequired": true,
            "isolationVerification": "blind_plate",
            "continuousMonitoring": true
          }
        }
      ]
    }
  },
  "nodeGraph": {
    "hot_work_workflow": {
      "name": "动火作业工作流",
      "nodes": [
        {
          "nodeId": "n1",
          "nodeRef": "填写-表单",
          "position": { "x": 100, "y": 100 }
        },
        {
          "nodeId": "n2",
          "nodeRef": "匹配-审批级别",
          "position": { "x": 300, "y": 100 }
        },
        {
          "nodeId": "n3",
          "nodeRef": "检测-冲突",
          "position": { "x": 500, "y": 100 }
        },
        {
          "nodeId": "n4",
          "nodeRef": "验证-资质证书",
          "position": { "x": 700, "y": 100 }
        },
        {
          "nodeId": "n5",
          "nodeRef": "审批-通用",
          "position": { "x": 900, "y": 100 }
        },
        {
          "nodeId": "n6",
          "nodeRef": "环境准入-闸门",
          "position": { "x": 1100, "y": 100 }
        },
        {
          "nodeId": "n7",
          "nodeRef": "执行-动火作业",
          "position": { "x": 1300, "y": 100 }
        },
        {
          "nodeId": "n8",
          "nodeRef": "签名-电子",
          "position": { "x": 1500, "y": 100 }
        }
      ],
      "edges": [
        { "from": "n1", "to": "n2", "condition": "data.work_zone && data.work_level" },
        { "from": "n2", "to": "n3" },
        { "from": "n3", "to": "n4", "condition": "!conflictDetected" },
        { "from": "n4", "to": "n5", "condition": "certificatesValid" },
        { "from": "n5", "to": "n6", "condition": "approved" },
        { "from": "n6", "to": "n7", "condition": "gateCleared" },
        { "from": "n7", "to": "n8" }
      ],
      "pluginInjection": {
        "condition": "data.work_level == 'special' && data.work_zone.includes('罐区')",
        "injectAfter": "n6",
        "pluginNodeRef": "plugin-罐区动火"
      }
    }
  }
}
